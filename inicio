<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Estudiantil</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-primary: #0a0d14;
    --bg-secondary: #111622;
    --bg-card: #151c2c;
    --bg-card-hover: #1a2236;
    --accent-blue: #3b82f6;
    --accent-blue-glow: rgba(59,130,246,0.25);
    --accent-blue-light: #60a5fa;
    --accent-dark: #1d3a6e;
    --text-primary: #e8eaf2;
    --text-secondary: #8b93b0;
    --text-muted: #4b5572;
    --border: rgba(59,130,246,0.12);
    --border-hover: rgba(59,130,246,0.35);
    --sidebar-width: 64px;
    --progress-done: 25;
    --shadow-card: 0 4px 24px rgba(0,0,0,0.4);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Sora', sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ─── LOGIN OVERLAY ─────────────────────────────────────────── */
  #login-overlay {
    position: fixed; inset: 0;
    background: linear-gradient(135deg, #060910 0%, #0d1525 100%);
    display: flex; align-items: center; justify-content: center;
    z-index: 1000;
    transition: opacity .5s ease;
  }
  #login-overlay.hidden { opacity: 0; pointer-events: none; }

  .login-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 44px 40px;
    width: 360px;
    box-shadow: 0 0 60px rgba(59,130,246,0.08), var(--shadow-card);
    animation: fadeUp .5s ease;
  }
  @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:none; } }

  .login-logo {
    width: 48px; height: 48px;
    background: linear-gradient(135deg, var(--accent-blue), #1d4ed8);
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; margin-bottom: 24px;
    box-shadow: 0 0 24px var(--accent-blue-glow);
  }
  .login-box h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 6px; }
  .login-box p { font-size: .85rem; color: var(--text-secondary); margin-bottom: 28px; }

  .field { margin-bottom: 16px; }
  .field label { display: block; font-size: .75rem; font-weight: 600; color: var(--text-secondary); letter-spacing: .05em; text-transform: uppercase; margin-bottom: 8px; }
  .field input, .field select {
    width: 100%; padding: 12px 14px;
    background: var(--bg-secondary); border: 1px solid var(--border);
    border-radius: 10px; color: var(--text-primary);
    font-family: 'Sora', sans-serif; font-size: .9rem;
    outline: none; transition: border-color .2s, box-shadow .2s;
  }
  .field input:focus, .field select:focus {
    border-color: var(--accent-blue);
    box-shadow: 0 0 0 3px var(--accent-blue-glow);
  }
  .field select option { background: var(--bg-secondary); }

  .btn-login {
    width: 100%; padding: 13px;
    background: linear-gradient(135deg, var(--accent-blue), #1d4ed8);
    border: none; border-radius: 10px;
    color: #fff; font-family: 'Sora', sans-serif;
    font-size: .95rem; font-weight: 600; cursor: pointer;
    margin-top: 8px; transition: opacity .2s, transform .15s;
    box-shadow: 0 4px 20px var(--accent-blue-glow);
  }
  .btn-login:hover { opacity: .9; transform: translateY(-1px); }
  .login-error {
    background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3);
    border-radius: 8px; padding: 10px 14px;
    font-size: .83rem; color: #f87171;
    margin-bottom: 14px; display: none;
  }
  .login-error.show { display: block; }

  /* ─── LAYOUT ────────────────────────────────────────────────── */
  .app { display: flex; min-height: 100vh; }

  /* SIDEBAR */
  .sidebar {
    width: var(--sidebar-width);
    background: var(--bg-secondary);
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column; align-items: center;
    padding: 20px 0; gap: 8px; position: fixed; top: 0; left: 0; bottom: 0;
    z-index: 10;
  }
  .sidebar-logo {
    width: 38px; height: 38px;
    background: linear-gradient(135deg, var(--accent-blue), #1d4ed8);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; margin-bottom: 16px;
    box-shadow: 0 0 20px var(--accent-blue-glow);
  }
  .nav-btn {
    width: 42px; height: 42px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background .2s, color .2s;
    color: var(--text-muted); border: none; background: transparent;
    font-size: 18px; position: relative;
  }
  .nav-btn:hover, .nav-btn.active {
    background: var(--accent-blue-glow); color: var(--accent-blue);
  }
  .nav-btn.active::before {
    content: '';
    position: absolute; left: -1px; top: 25%; bottom: 25%;
    width: 3px; border-radius: 0 3px 3px 0;
    background: var(--accent-blue);
  }
  .sidebar-spacer { flex: 1; }

  /* TOPBAR */
  .topbar {
    position: fixed; top: 0; left: var(--sidebar-width); right: 0; height: 60px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 28px; z-index: 9;
  }
  .topbar-left { display: flex; align-items: center; gap: 14px; }
  .hamburger { font-size: 20px; color: var(--text-secondary); cursor: pointer; }
  .topbar-title { font-size: .85rem; color: var(--text-secondary); font-weight: 500; }
  .topbar-right { display: flex; align-items: center; gap: 14px; }

  .role-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: .7rem; padding: 4px 10px;
    border-radius: 20px; font-weight: 500;
    text-transform: uppercase; letter-spacing: .06em;
  }
  .role-badge.student { background: rgba(59,130,246,0.15); color: var(--accent-blue-light); border: 1px solid var(--border); }
  .role-badge.admin { background: rgba(234,179,8,0.12); color: #fbbf24; border: 1px solid rgba(234,179,8,0.25); }

  .notif-btn {
    width: 36px; height: 36px; border-radius: 10px;
    background: var(--bg-card); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--text-secondary); font-size: 16px;
    position: relative; transition: border-color .2s;
  }
  .notif-btn:hover { border-color: var(--accent-blue); color: var(--accent-blue); }
  .notif-dot {
    position: absolute; top: 7px; right: 7px;
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent-blue); border: 1.5px solid var(--bg-secondary);
  }

  .avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 700; cursor: pointer;
    border: 2px solid var(--border); transition: border-color .2s;
    position: relative;
  }
  .avatar:hover { border-color: var(--accent-blue); }

  /* MAIN */
  .main {
    margin-left: var(--sidebar-width);
    padding-top: 60px;
    flex: 1; min-height: 100vh;
  }
  .content { padding: 32px 28px; max-width: 860px; }

  /* WELCOME */
  .welcome-section { margin-bottom: 30px; }
  .welcome-section h1 {
    font-size: 1.55rem; font-weight: 700;
    background: linear-gradient(90deg, #e8eaf2, var(--accent-blue-light));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    margin-bottom: 4px;
  }
  .welcome-section p { font-size: .85rem; color: var(--text-secondary); }

  /* HOURS CARD */
  .hours-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 26px 28px;
    display: flex; align-items: center; justify-content: space-between;
    box-shadow: var(--shadow-card);
    margin-bottom: 28px;
    transition: border-color .3s;
    position: relative; overflow: hidden;
  }
  .hours-card::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(59,130,246,0.04) 0%, transparent 60%);
    pointer-events: none;
  }
  .hours-card:hover { border-color: var(--border-hover); }

  .hours-info { flex: 1; }
  .hours-label { font-size: .78rem; color: var(--text-secondary); font-weight: 500; letter-spacing: .03em; margin-bottom: 10px; }
  .hours-value { font-size: 2.2rem; font-weight: 700; margin-bottom: 16px; line-height: 1; }
  .hours-value span { font-size: 1.1rem; color: var(--text-secondary); font-weight: 400; }

  .progress-bar-wrap { margin-top: 4px; }
  .progress-bar-bg {
    height: 6px; background: rgba(255,255,255,0.06);
    border-radius: 99px; overflow: hidden; width: 260px; max-width: 100%;
  }
  .progress-bar-fill {
    height: 100%;
    width: calc(var(--progress-done) * 1%);
    background: linear-gradient(90deg, var(--accent-blue), var(--accent-blue-light));
    border-radius: 99px;
    box-shadow: 0 0 10px var(--accent-blue-glow);
    transition: width 1.2s cubic-bezier(.4,0,.2,1);
  }
  .progress-pct { font-size: .78rem; color: var(--text-secondary); margin-top: 8px; font-family: 'JetBrains Mono', monospace; }

  /* DONUT */
  .donut-wrap { position: relative; width: 96px; height: 96px; flex-shrink: 0; }
  .donut-svg { transform: rotate(-90deg); }
  .donut-bg { fill: none; stroke: rgba(255,255,255,0.05); stroke-width: 9; }
  .donut-fill {
    fill: none;
    stroke: url(#donut-grad);
    stroke-width: 9;
    stroke-linecap: round;
    stroke-dasharray: 251.2;
    stroke-dashoffset: calc(251.2 * (1 - var(--progress-done) / 100));
    transition: stroke-dashoffset 1.2s cubic-bezier(.4,0,.2,1);
    filter: drop-shadow(0 0 6px rgba(59,130,246,0.5));
  }
  .donut-center {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: .85rem; font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent-blue-light);
  }

  /* ADMIN EDIT PANEL */
  .admin-panel {
    background: linear-gradient(135deg, rgba(234,179,8,0.06), rgba(234,179,8,0.02));
    border: 1px solid rgba(234,179,8,0.2);
    border-radius: 16px;
    padding: 20px 24px;
    margin-bottom: 28px;
    display: none;
    animation: fadeUp .3s ease;
  }
  .admin-panel.visible { display: block; }
  .admin-panel h3 { font-size: .9rem; color: #fbbf24; font-weight: 600; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }

  .admin-fields { display: flex; gap: 16px; flex-wrap: wrap; align-items: flex-end; }
  .admin-field { display: flex; flex-direction: column; gap: 6px; }
  .admin-field label { font-size: .72rem; color: var(--text-secondary); font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
  .admin-field input[type="number"] {
    width: 120px; padding: 10px 12px;
    background: var(--bg-secondary); border: 1px solid rgba(234,179,8,0.2);
    border-radius: 9px; color: var(--text-primary);
    font-family: 'JetBrains Mono', monospace; font-size: .9rem; outline: none;
    transition: border-color .2s, box-shadow .2s;
  }
  .admin-field input[type="number"]:focus {
    border-color: #fbbf24;
    box-shadow: 0 0 0 3px rgba(234,179,8,0.12);
  }
  .btn-update {
    padding: 10px 20px;
    background: rgba(234,179,8,0.15);
    border: 1px solid rgba(234,179,8,0.3);
    border-radius: 9px;
    color: #fbbf24; font-family: 'Sora', sans-serif;
    font-size: .85rem; font-weight: 600; cursor: pointer;
    transition: background .2s, transform .15s;
    align-self: flex-end;
  }
  .btn-update:hover { background: rgba(234,179,8,0.25); transform: translateY(-1px); }
  .update-msg {
    font-size: .78rem; color: #86efac;
    margin-top: 12px; opacity: 0;
    transition: opacity .4s;
    display: flex; align-items: center; gap: 6px;
  }
  .update-msg.show { opacity: 1; }

  /* QUICK ACCESS */
  .section-title { font-size: .78rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 16px; }
  .quick-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .quick-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 26px 22px;
    cursor: pointer;
    transition: border-color .25s, transform .2s, background .2s;
    position: relative; overflow: hidden;
  }
  .quick-card::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(59,130,246,0.05), transparent 60%);
    opacity: 0; transition: opacity .3s; pointer-events: none;
  }
  .quick-card:hover { border-color: var(--border-hover); transform: translateY(-2px); }
  .quick-card:hover::after { opacity: 1; }

  .quick-icon {
    width: 48px; height: 48px; border-radius: 14px;
    background: rgba(59,130,246,0.12);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; margin-bottom: 16px;
    border: 1px solid rgba(59,130,246,0.2);
    transition: background .2s;
  }
  .quick-card:hover .quick-icon { background: rgba(59,130,246,0.22); }

  .quick-card h3 { font-size: .95rem; font-weight: 600; margin-bottom: 8px; }
  .quick-card p { font-size: .78rem; color: var(--text-secondary); line-height: 1.5; }

  /* LOGOUT BTN */
  .btn-logout {
    width: 38px; height: 38px; border-radius: 10px;
    background: var(--bg-card); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--text-secondary); font-size: 16px;
    transition: border-color .2s, color .2s;
  }
  .btn-logout:hover { border-color: #f87171; color: #f87171; }

  /* TOOLTIP */
  [data-tip] { position: relative; }
  [data-tip]:hover::after {
    content: attr(data-tip);
    position: absolute; bottom: calc(100% + 8px); left: 50%; transform: translateX(-50%);
    background: #1e2a40; border: 1px solid var(--border);
    color: var(--text-primary); font-size: .72rem; font-family: 'Sora', sans-serif;
    white-space: nowrap; padding: 5px 10px; border-radius: 8px;
    pointer-events: none; z-index: 99;
  }

  /* READONLY NOTICE */
  .readonly-notice {
    display: none;
    background: rgba(59,130,246,0.07);
    border: 1px solid rgba(59,130,246,0.15);
    border-radius: 10px; padding: 10px 14px;
    font-size: .78rem; color: var(--text-secondary);
    margin-bottom: 20px;
    align-items: center; gap: 8px;
  }
  .readonly-notice.visible { display: flex; }

  @media (max-width: 540px) {
    .quick-grid { grid-template-columns: 1fr; }
    .hours-value { font-size: 1.6rem; }
    .progress-bar-bg { width: 180px; }
    .admin-fields { flex-direction: column; }
  }
</style>
</head>
<body>

<!-- ═══════════════════ LOGIN ═══════════════════ -->
<div id="login-overlay">
  <div class="login-box">
    <div class="login-logo">🎓</div>
    <h2>Bienvenido</h2>
    <p>Ingresa con tus credenciales para continuar</p>

    <div id="login-error" class="login-error">Usuario o contraseña incorrectos.</div>

    <div class="field">
      <label>Cuenta</label>
      <select id="sel-user">
        <option value="">— Selecciona un usuario —</option>
        <option value="student">Juan Pérez (Estudiante)</option>
        <option value="admin">Admin (Coordinador)</option>
      </select>
    </div>
    <div class="field">
      <label>Contraseña</label>
      <input type="password" id="inp-pass" placeholder="••••••••" autocomplete="off">
    </div>
    <button class="btn-login" onclick="doLogin()">Iniciar sesión</button>

    <p style="font-size:.72rem;color:var(--text-muted);margin-top:18px;line-height:1.6;">
      Demo: <strong style="color:var(--text-secondary)">estudiante</strong> → contraseña <code style="color:var(--accent-blue-light)">1234</code><br>
      <strong style="color:var(--text-secondary)">admin</strong> → contraseña <code style="color:#fbbf24">admin2024</code>
    </p>
  </div>
</div>

<!-- ═══════════════════ APP ═══════════════════ -->
<div class="app">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-logo">🎓</div>
    <button class="nav-btn active" data-tip="Inicio">🏠</button>
    <button class="nav-btn" data-tip="Proyectos">📁</button>
    <button class="nav-btn" data-tip="Mis Horas">🕐</button>
    <div class="sidebar-spacer"></div>
    <button class="nav-btn btn-logout" data-tip="Cerrar sesión" onclick="doLogout()">⬅️</button>
  </aside>

  <!-- TOPBAR -->
  <header class="topbar">
    <div class="topbar-left">
      <span class="hamburger">☰</span>
      <span class="topbar-title">Dashboard</span>
    </div>
    <div class="topbar-right">
      <span id="role-badge" class="role-badge student">Estudiante</span>
      <button class="notif-btn"><span>🔔</span><span class="notif-dot"></span></button>
      <div class="avatar" id="avatar-initials">JP</div>
    </div>
  </header>

  <!-- MAIN CONTENT -->
  <main class="main">
    <div class="content">

      <!-- WELCOME -->
      <div class="welcome-section">
        <h1 id="welcome-name">¡Bienvenido, Juan Pérez!</h1>
        <p id="welcome-sub">Aquí tienes el resumen de tu actividad académica.</p>
      </div>

      <!-- READONLY NOTICE (student) -->
      <div class="readonly-notice visible" id="readonly-notice">
        🔒 Las estadísticas de progreso solo pueden ser modificadas por un Coordinador.
      </div>

      <!-- ADMIN EDIT PANEL -->
      <div class="admin-panel" id="admin-panel">
        <h3>⚙️ Panel de Administrador — Editar progreso</h3>
        <div class="admin-fields">
          <div class="admin-field">
            <label>Horas completadas</label>
            <input type="number" id="inp-done" min="0" max="999" value="20">
          </div>
          <div class="admin-field">
            <label>Total de horas</label>
            <input type="number" id="inp-total" min="1" max="999" value="80">
          </div>
          <button class="btn-update" onclick="applyUpdate()">Actualizar</button>
        </div>
        <div class="update-msg" id="update-msg">✅ Progreso actualizado correctamente.</div>
      </div>

      <!-- HOURS CARD -->
      <div class="hours-card">
        <div class="hours-info">
          <div class="hours-label">Horas completadas</div>
          <div class="hours-value">
            <span id="disp-done">20</span> <span>/ <span id="disp-total">80</span> horas</span>
          </div>
          <div class="progress-bar-wrap">
            <div class="progress-bar-bg">
              <div class="progress-bar-fill" id="bar-fill"></div>
            </div>
            <div class="progress-pct" id="pct-label">25%</div>
          </div>
        </div>

        <div class="donut-wrap">
          <svg class="donut-svg" width="96" height="96" viewBox="0 0 96 96">
            <defs>
              <linearGradient id="donut-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#3b82f6"/>
                <stop offset="100%" stop-color="#93c5fd"/>
              </linearGradient>
            </defs>
            <circle class="donut-bg" cx="48" cy="48" r="40"/>
            <circle class="donut-fill" id="donut-fill" cx="48" cy="48" r="40"/>
          </svg>
          <div class="donut-center" id="donut-pct">25%</div>
        </div>
      </div>

      <!-- QUICK ACCESS -->
      <div class="section-title">Accesos rápidos</div>
      <div class="quick-grid">
        <div class="quick-card">
          <div class="quick-icon">📅</div>
          <h3>Ver proyectos</h3>
          <p>Explora los proyectos que otorgan horas sociales</p>
        </div>
        <div class="quick-card">
          <div class="quick-icon">🕐</div>
          <h3>Mis horas</h3>
          <p>Consulta el seguimiento de tus horas realizadas</p>
        </div>
      </div>

    </div>
  </main>
</div>

<script>
// ── Data ──────────────────────────────────────────────────────
const USERS = {
  student: { pass: '1234',      role: 'student', name: 'Juan Pérez',   initials: 'JP' },
  admin:   { pass: 'admin2024', role: 'admin',   name: 'Coordinador',  initials: 'AD' }
};

let state = {
  done: 20,
  total: 80,
  role: null
};

// ── Login / Logout ────────────────────────────────────────────
function doLogin() {
  const key  = document.getElementById('sel-user').value;
  const pass = document.getElementById('inp-pass').value.trim();
  const err  = document.getElementById('login-error');

  if (!key || !USERS[key] || USERS[key].pass !== pass) {
    err.classList.add('show');
    return;
  }
  err.classList.remove('show');

  const user = USERS[key];
  state.role = user.role;

  // Set UI
  document.getElementById('welcome-name').textContent = `¡Bienvenido, ${user.name}!`;
  document.getElementById('welcome-sub').textContent =
    user.role === 'admin'
      ? 'Panel de coordinación — puedes editar el progreso de los estudiantes.'
      : 'Aquí tienes el resumen de tu actividad académica.';

  document.getElementById('avatar-initials').textContent = user.initials;

  const badge = document.getElementById('role-badge');
  badge.textContent = user.role === 'admin' ? 'Administrador' : 'Estudiante';
  badge.className   = 'role-badge ' + user.role;

  // Admin panel visibility
  document.getElementById('admin-panel').classList.toggle('visible', user.role === 'admin');
  document.getElementById('readonly-notice').classList.toggle('visible', user.role === 'student');

  // Hide login
  document.getElementById('login-overlay').classList.add('hidden');

  // Animate chart after a tick
  setTimeout(renderProgress, 100);
}

function doLogout() {
  state.role = null;
  document.getElementById('sel-user').value = '';
  document.getElementById('inp-pass').value = '';
  document.getElementById('login-error').classList.remove('show');
  document.getElementById('login-overlay').classList.remove('hidden');
}

// ── Progress rendering ────────────────────────────────────────
function renderProgress() {
  const pct = Math.min(100, Math.max(0, Math.round(state.done / state.total * 100)));

  document.getElementById('disp-done').textContent  = state.done;
  document.getElementById('disp-total').textContent = state.total;
  document.getElementById('pct-label').textContent  = pct + '%';
  document.getElementById('donut-pct').textContent  = pct + '%';

  // CSS variable drives both bar and donut via CSS calc()
  document.documentElement.style.setProperty('--progress-done', pct);

  // Donut (manual because CSS var in SVG stroke-dashoffset is limited on some browsers)
  const circumference = 2 * Math.PI * 40; // 251.2
  const offset = circumference * (1 - pct / 100);
  document.getElementById('donut-fill').style.strokeDashoffset = offset;

  // Bar
  document.getElementById('bar-fill').style.width = pct + '%';
}

// ── Admin update ──────────────────────────────────────────────
function applyUpdate() {
  if (state.role !== 'admin') return; // guard (belt + suspenders)

  const done  = parseInt(document.getElementById('inp-done').value,  10);
  const total = parseInt(document.getElementById('inp-total').value, 10);

  if (isNaN(done) || isNaN(total) || total < 1 || done < 0 || done > total) {
    alert('Valores inválidos. Asegúrate de que las horas completadas no superen el total.');
    return;
  }

  state.done  = done;
  state.total = total;
  renderProgress();

  const msg = document.getElementById('update-msg');
  msg.classList.add('show');
  setTimeout(() => msg.classList.remove('show'), 2800);
}

// ── Nav active state (visual only) ───────────────────────────
document.querySelectorAll('.nav-btn:not(.btn-logout)').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  });
});

// Enter key on password field
document.getElementById('inp-pass').addEventListener('keydown', e => {
  if (e.key === 'Enter') doLogin();
});

// Initial render (with current state values, no animation)
renderProgress();
</script>
</body>
